package render

templ forbidden(requestId string) {
	<div style="display: flex; align-items: center; padding: 2rem;">
		<img src="https://i.imgur.com/GXItvHZ.png" alt="Logo" style="max-width: 120px; margin-right: 2rem;" />
		<div>
			<h1>403 Forbidden</h1>
			<p>You do not have permission to access this resource.</p>
			<pre>X-Request-ID { requestId } </pre>
		</div>
	</div>
}

templ Forbidden(requestId string) {
	@View("403 | sentinez", forbidden(requestId))
}
